POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://symposium:changeme@db:5432/symposium?sslmode=disable
DOMAIN=symposium.example.com

# Deployment targets (used by the Makefile)
NAS_HOST=user@nas.example.com
NAS_DIR=~/symposium
VPS_HOST=user@vps.example.com
VPS_DIR=/opt/symposium

# --- LLM provider ---
# LLM_PROVIDER selects the backend. Default: gemini.
#   gemini -> Google Generative Language API (free tier fits a 2/day schedule)
#   ollama -> Local Ollama instance (fallback path; see docker-compose.orchestrator.yml)
LLM_PROVIDER=gemini

# Gemini: comma-separated list of API keys. The client rotates through them
# and fails over to the next key on 429/403/5xx errors.
GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash

# Ollama (only used when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
